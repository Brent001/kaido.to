{
  "name": "kaido",
  "version": "1.0.0",
  "description": "📦 A scraper package serving anime information from kaido.to",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "type": "module",
  "scripts": {
    "lint": "tsc",
    "build": "tsup",
    "ci": "tsc && pnpm test && tsup",
    "test": "vitest run --config vitest.config.ts",
    "prepare": "node .husky/install.mjs",
    "format": "prettier --cache --write .",
    "format:check": "prettier --cache --check ."
  },
  "author": {
    "name": "Brent Abrazaldo",
    "url": "https://github.com/Brent001"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Brent001/kaido.to.git"
  },
  "bugs": {
    "url": "https://github.com/Brent001/kaido.to/issues"
  },
  "homepage": "https://github.com/Brent001/kaido.to#readme",
  "keywords": [
    "anime",
    "kaido",
    "kaido.to",
    "scraper",
    "package"
  ],
  "dependencies": {
    "axios": "^1.7.9",
    "cheerio": "1.0.0",
    "crypto-js": "^4.2.0",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.10.3",
    "husky": "^9.1.7",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "files": [
    "dist",
    "LICENSE",
    "package.json"
  ]
}
